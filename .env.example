# Copy this to .env.local and fill in your Firebase values
# Get all values from: Firebase Console → Project Settings → Your apps → Web app

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# NOTE: No storage bucket needed — images stored as Base64 in Firestore

# WhatsApp number with country code (no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=966500000000
